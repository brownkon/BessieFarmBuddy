<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/voice_overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:elevation="10dp"
    android:padding="4dp">

    <View
        android:id="@+id/voice_pill_ring"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@drawable/bg_voice_overlay_ring" />

    <LinearLayout
        android:id="@+id/voice_pill_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/bg_voice_overlay">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/voice_mascot_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_voice_avatar_ring" />

            <ImageView
                android:id="@+id/icon_voice_mascot"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_voice_avatar_clip"
                android:clipToOutline="true"
                android:contentDescription="Voice Mascot"
                android:padding="2dp"
                android:scaleType="fitCenter"
                android:src="@mipmap/ic_launcher_foreground" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_voice_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LISTENING"
                android:textAllCaps="true"
                android:textColor="#FF6A00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:id="@+id/text_voice_detail"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="8"
                android:scrollbars="vertical"
                android:requiresFadingEdge="vertical"
                android:fadingEdgeLength="12dp"
                android:lineSpacingExtra="3dp"
                android:text="Waiting for voice input"
                android:textColor="#F4F7FA"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>

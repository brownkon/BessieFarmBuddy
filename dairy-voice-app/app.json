{
  "expo": {
    "name": "Bovi AI",
    "slug": "dairy-voice-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dairyvoiceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow DairyVoice to recognize your voice for commands.",
        "NSMicrophoneUsageDescription": "Allow DairyVoice to access the microphone for voice commands.",
        "NSLocationWhenInUseUsageDescription": "Allow DairyVoice to capture your location when you submit a message."
      },
      "bundleIdentifier": "com.voidedflyer.dairyvoiceapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#20252B",
        "foregroundImage": "./assets/images/icon-adaptive-padded.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.voidedflyer.dairyvoiceapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "./plugins/withWakeWordModel",
        {
          "source": "./native-assets/model",
          "required": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-adaptive-padded.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#20252B",
          "dark": {
            "backgroundColor": "#20252B"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow DairyVoice to access the microphone for voice commands.",
          "speechRecognitionPermission": "Allow DairyVoice to recognize your voice for commands."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}

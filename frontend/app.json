{
  "expo": {
    "name": "Maggie",
    "slug": "frontend",
    "scheme": "maggie-farm-buddy",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/boviLogo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f1117",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/e2533d92-7eb8-4dc0-aac1-542c1001dda1"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.konnerbrown.bessie.test99"
    },
    "android": {
      "versionCode": 7,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/boviLogo.png",
        "backgroundColor": "#0f1117"
      },
      "package": "com.maggie.farmbuddy",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Bessie to use the microphone to listen for voice commands.",
          "speechRecognitionPermission": "Allow Bessie to use speech recognition to understand your farm commands.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 34
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e2533d92-7eb8-4dc0-aac1-542c1001dda1"
      }
    }
  }
}